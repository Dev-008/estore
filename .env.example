# Frontend Environment Variables
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=storeMX
VITE_APP_VERSION=1.0.0

# EmailJS Configuration (for frontend email sending)
# Get these from: https://dashboard.emailjs.com/
