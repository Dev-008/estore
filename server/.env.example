# Email Service Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@storemx.com

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# For local development: mongodb://localhost:27017/storemx
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/storemx?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/storemx
